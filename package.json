{
  "name": "bazaar-build-finder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "inspect:data": "tsx scripts/inspect-bazaar-data.ts",
    "generate:builds": "tsx scripts/generate-builds.ts",
    "export:effect-corpus": "tsx scripts/export-effect-rawtext-corpus.ts",
    "evaluate:effect-parser": "tsx scripts/evaluate-effect-parser.ts",
    "import:pattern-candidates": "tsx scripts/import-pattern-candidates.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "vite": "^7.2.7",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
